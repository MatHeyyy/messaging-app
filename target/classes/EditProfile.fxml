<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="EditProfileController"
            prefWidth="450" prefHeight="320">

    <top>
        <HBox style="-fx-background-color: #202C33; -fx-padding: 15;" alignment="CENTER">
            <Label text="Edit Profile" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 30;" alignment="CENTER">
            <Label text="Username" style="-fx-font-size: 14;"/>
            <TextField fx:id="usernameField" prefHeight="40" promptText="Enter your name" />

            <Label text="Status" style="-fx-font-size: 14;"/>
            <TextField fx:id="statusField" prefHeight="40" promptText="Online" />

            <Button text="Save Changes" fx:id="saveBtn" style="-fx-background-color: #00BFFF; -fx-text-fill: white; -fx-font-size: 16; -fx-padding: 10 30;" />
        </VBox>
    </center>
</BorderPane>