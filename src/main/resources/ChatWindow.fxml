<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ChatWindowController"
            prefWidth="700" prefHeight="600">

    <top>
        <HBox style="-fx-background-color: #202C33; -fx-padding: 12 20;" spacing="10">
            <Label fx:id="chatTitle" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="Chat with Someone" />
            <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
                <Button text="❤️ Like chat" fx:id="likeBtn" 
        style="-fx-background-color: #00BFFF; 
               -fx-text-fill: white; 
               -fx-focus-color: transparent; 
               -fx-faint-focus-color: transparent; 
               -fx-background-insets: 0; 
               -fx-focus-traversable: false;" />
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: #111B21;">
            <VBox fx:id="messageContainer" spacing="10" style="-fx-padding: 15;" />
        </ScrollPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #202C33; -fx-padding: 10;" spacing="10">
            <TextField fx:id="messageField" promptText="Type a message..." HBox.hgrow="ALWAYS" prefHeight="40" />
            <Button text="Send" fx:id="sendBtn" style="-fx-background-color: #00BFFF; -fx-text-fill: white; -fx-font-size: 15;" />
        </HBox>
    </bottom>
</BorderPane>